# Server
PORT=8080
NODE_ENV=development
CLIENT_WEB_ORIGIN=http://localhost:5173
CLIENT_FLUTTER_ORIGIN=http://localhost:4000

# Database
MONGODB_URI=mongodb://localhost:27017/netshop_mlm
MONGODB_DB_NAME=netshop_mlm

# Auth
JWT_ACCESS_SECRET=replace-with-strong-secret
JWT_REFRESH_SECRET=replace-with-even-stronger-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
PASSWORD_SALT_ROUNDS=10

# Integrations
REDIS_URL=redis://localhost:6379
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Feature flags
ENABLE_ACTIVITY_STREAM=true
ENABLE_SOCKET_NOTIFICATIONS=true
